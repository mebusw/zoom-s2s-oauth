# =============================================================================
# Zoom Server-to-Server OAuth 凭证配置
# =============================================================================
# 路径: ~/.agents/skills/zoom-s2s-oauth/.env
#
# 获取方式 (Zoom Marketplace):
# 1. https://marketplace.zoom.us/develop/create
# 2. 选择 "Server-to-Server OAuth" → 创建 App
# 3. 填写 Account ID / Client ID / Client Secret
# 4. 在 App 配置里开通需要的 Scope
# =============================================================================

# Account ID (可在 Zoom App 配置页找到)
ZOOM_ACCOUNT_ID=bQ60RYqgQjGGYX1BI67ExQ

# Client ID
ZOOM_CLIENT_ID=f08M8T4LQtSuExP3VkrzTQ

# Client Secret
ZOOM_CLIENT_SECRET=eNvy78T2IJoOBxnIpfdqCKtAJirTIM2A

# 默认用户 (邮箱 或 user_id)
ZOOM_USER_ID=service@uperform.cn
